{
    "manufacturer": "Matthijs Muller",
    "keyboard_name": "Serene Industries - Icebreaker HE",
    "maintainer": "Matthijs Muller",
    "bootloader": "stm32-dfu",
    "build": {
        "lto": false
    },
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": false,
        "console": true,
        "extrakey": true,
        "rgblight": true,
        "nkro": true,
        "encoder": true
    },
    "processor": "STM32F411",
    "url": "https://www.github.com/SmollChungus",
    "usb": {
        "device_version": "0.0.1",
        "pid": "0x0010",
        "shared_endpoint": {
            "keyboard": true
        },
        "vid": "0x5363"
    },
    "encoder": {
        "rotary": [
            { "pin_a": "B14", "pin_b": "B13"}
        ]
    },
    "ws2812": {
        "driver": "pwm"
    },
    "rgblight": {
        "animations": {
            "breathing": true
        },
        "brightness_steps": 10,
        "led_count": 68,
        "saturation_steps": 8,
        "max_brightness": 100
    },
